<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bang dieu khien - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .badge-clickable {
            cursor: pointer; display: inline-block;
            transition: filter .15s, transform .12s;
        }
        .badge-clickable:hover { filter: brightness(.9); transform: scale(1.06); }

        .pending-badge {
            background: #fef3c7; color: #92400e;
            font-size: 11px; font-weight: 700;
            padding: 2px 8px; border-radius: 20px; margin-left: 8px;
        }

        .modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.5); z-index: 1000;
            align-items: center; justify-content: center;
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: #fff; border-radius: 20px; width: 520px;
            max-width: 95vw; max-height: 90vh; overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,.25);
            animation: popUp .18s ease;
        }
        @keyframes popUp {
            from { opacity:0; transform:scale(.95) translateY(10px); }
            to   { opacity:1; transform:scale(1) translateY(0); }
        }
        .modal-head {
            padding: 20px 24px 16px; border-bottom: 1px solid #f1f5f9;
            display: flex; align-items: center; justify-content: space-between;
        }
        .modal-head h3 { font-size: 17px; font-weight: 700; color: #1e293b; margin: 0; }
        .modal-close {
            width: 32px; height: 32px; border-radius: 8px; background: #f1f5f9;
            border: none; cursor: pointer; font-size: 18px; color: #64748b;
            display: flex; align-items: center; justify-content: center;
        }
        .modal-close:hover { background: #e2e8f0; }
        .modal-body { padding: 20px 24px; }
        .modal-car-img { width:100%; height:160px; object-fit:cover; border-radius:12px; margin-bottom:16px; }
        .modal-car-ph {
            width:100%; height:160px; background:#f1f5f9; border-radius:12px;
            margin-bottom:16px; display:flex; align-items:center; justify-content:center;
        }
        .sec-title {
            font-size:11px; font-weight:700; text-transform:uppercase;
            letter-spacing:.8px; color:#94a3b8; margin-bottom:8px; margin-top:16px;
        }
        .sec-title:first-child { margin-top:0; }
        .detail-row {
            display:flex; justify-content:space-between; align-items:center;
            padding:8px 0; border-bottom:1px solid #f8fafc; font-size:13px;
        }
        .detail-row:last-child { border-bottom:none; }
        .detail-row .lbl { color:#64748b; }
        .detail-row .val { font-weight:600; color:#1e293b; }
        .total-row {
            background:#eff6ff; border-radius:10px; padding:12px 16px;
            display:flex; justify-content:space-between; align-items:center; margin-top:14px;
        }
        .total-row .lbl { font-size:14px; font-weight:600; color:#1e40af; }
        .total-row .val { font-size:22px; font-weight:800; color:#2563eb; }
        .modal-actions {
            padding:16px 24px; border-top:1px solid #f1f5f9;
            display:flex; gap:10px; flex-wrap:wrap;
        }
        .mab {
            flex:1; min-width:110px; padding:11px 14px; border-radius:10px;
            border:none; font-size:13px; font-weight:600; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:7px;
            transition:opacity .15s;
        }
        .mab:hover { opacity:.85; }
        .mab.approve { background:#16a34a; color:#fff; }
        .mab.start   { background:#d97706; color:#fff; }
        .mab.done    { background:#4f46e5; color:#fff; }
        .mab.cancel  { background:#dc2626; color:#fff; }
        .mab.neutral { background:#f1f5f9; color:#475569; }
    </style>
</head>
<body class="admin-body">

<%- include('../partials/admin-sidebar', { user, adminPage: 'dashboard' }) %>

<div class="admin-content">
    <div class="admin-topbar">
        <h2>Chao buoi sang, Admin! &#x1F44B;</h2>
        <button class="btn btn-primary" id="btnNewCar">+ Them xe moi</button>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon blue">&#x1F4B0;</div>
            <div class="stat-body">
                <div class="stat-label">Doanh thu thang</div>
                <div class="stat-val"><%= Number(stats.monthRevenue||0).toLocaleString('vi-VN') %>d</div>
                <div class="stat-change green">Thang nay</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">&#x1F697;</div>
            <div class="stat-body">
                <div class="stat-label">Xe dang cho thue</div>
                <div class="stat-val"><%= stats.rentedCars||0 %> / <%= stats.totalCars||0 %></div>
                <div class="stat-change gray">Hien tai</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">&#x23F0;</div>
            <div class="stat-body">
                <div class="stat-label">Don cho duyet</div>
                <div class="stat-val"><%= stats.pendingCount||0 %></div>
                <div class="stat-change <%= (stats.pendingCount||0)>0?'red':'green' %>">
                    <%= (stats.pendingCount||0)>0 ? 'Can xu ly' : 'Da xu ly het' %>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon purple">&#x1F465;</div>
            <div class="stat-body">
                <div class="stat-label">Khach hang moi (30 ngay)</div>
                <div class="stat-val"><%= stats.newCustomers||0 %></div>
                <div class="stat-change green">Thang nay</div>
            </div>
        </div>
    </div>

    <!-- Doi xe -->
    <div class="admin-card">
        <div class="card-head">
            <h3>Trang thai doi xe</h3>
            <a href="/admin/cars" class="link-more">Quan ly xe &rarr;</a>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ten xe</th><th>Bien so</th><th>Loai xe</th>
                    <th>Trang thai</th><th>Gia thue/ngay</th>
                </tr>
            </thead>
            <tbody>
                <% if (!recentCars || recentCars.length===0) { %>
                    <tr><td colspan="5" style="text-align:center;padding:32px;color:#94a3b8">Chua co xe nao.</td></tr>
                <% } %>
                <% (recentCars||[]).forEach(function(car){ %>
                <tr>
                    <td><strong><%= car.name %></strong></td>
                    <td><span style="background:#f1f5f9;color:#475569;padding:3px 8px;border-radius:6px;font-size:12px;font-weight:600"><%= car.licensePlate %></span></td>
                    <td style="font-size:13px;color:#475569"><%= car.type %></td>
                    <td><%- statusBadge(car.status) %></td>
                    <td style="font-weight:700;color:#2563eb"><%= Number(car.pricePerDay).toLocaleString('vi-VN') %>d</td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Don dat xe — dung index de map sang bookingsData -->
    <div class="admin-card" style="margin-top:20px">
        <div class="card-head">
            <h3>
                Don dat xe gan day
                <% if ((stats.pendingCount||0)>0) { %>
                    <span class="pending-badge"><%= stats.pendingCount %> cho duyet</span>
                <% } %>
            </h3>
            <a href="/admin/bookings" class="link-more">Xem tat ca &rarr;</a>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Khach hang</th><th>Xe</th>
                    <th>Ngay thue</th><th>Tong tien</th>
                    <th>Trang thai</th>
                </tr>
            </thead>
            <tbody>
                <% if (!recentBookings || recentBookings.length===0) { %>
                    <tr><td colspan="5" style="text-align:center;padding:32px;color:#94a3b8">Chua co don dat xe nao.</td></tr>
                <% } %>
                <% (recentBookings||[]).forEach(function(b, idx){
                    var days = Math.max(1, Math.ceil(
                        (new Date(b.endDate)-new Date(b.startDate))/(1000*60*60*24)
                    ));
                    var total = b.totalAmount || (b.car ? b.car.pricePerDay*days : 0);
                %>
                <tr>
                    <td style="font-size:13px">
                        <div style="font-weight:600"><%= b.customer ? b.customer.fullName : '—' %></div>
                        <div style="font-size:11px;color:#94a3b8"><%= b.customer ? b.customer.email : '' %></div>
                    </td>
                    <td style="font-size:13px;font-weight:600"><%= b.car ? b.car.name : '—' %></td>
                    <td style="font-size:12px;color:#64748b"><%= new Date(b.startDate).toLocaleDateString('vi-VN') %></td>
                    <td style="font-weight:700;color:#2563eb;font-size:13px"><%= Number(total).toLocaleString('vi-VN') %>d</td>
                    <td>
                        <span class="badge-clickable" data-idx="<%= idx %>">
                            <%- statusBadge(b.status) %>
                        </span>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="detailModal">
    <div class="modal-box">
        <div class="modal-head">
            <h3 id="modalTitle">Chi tiet don dat xe</h3>
            <button class="modal-close" id="modalCloseBtn">&#x2715;</button>
        </div>
        <div class="modal-body">
            <img id="mCarImg" class="modal-car-img" src="" alt="" style="display:none">
            <div id="mCarPh" class="modal-car-ph">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                    <path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/>
                    <rect x="9" y="11" width="14" height="10" rx="2"/>
                    <circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                </svg>
            </div>
            <div class="sec-title">Thong tin xe</div>
            <div class="detail-row"><span class="lbl">Ten xe</span>  <span class="val" id="mCarName">—</span></div>
            <div class="detail-row"><span class="lbl">Bien so</span> <span class="val" id="mCarPlate">—</span></div>
            <div class="sec-title">Khach hang</div>
            <div class="detail-row"><span class="lbl">Ho ten</span>        <span class="val" id="mCusName">—</span></div>
            <div class="detail-row"><span class="lbl">Email</span>         <span class="val" id="mCusEmail">—</span></div>
            <div class="detail-row"><span class="lbl">So dien thoai</span> <span class="val" id="mCusPhone">—</span></div>
            <div class="sec-title">Thoi gian thue</div>
            <div class="detail-row"><span class="lbl">Nhan xe</span> <span class="val" id="mStart">—</span></div>
            <div class="detail-row"><span class="lbl">Tra xe</span>  <span class="val" id="mEnd">—</span></div>
            <div class="detail-row"><span class="lbl">So ngay</span> <span class="val" id="mDays">—</span></div>
            <div id="mNoteWrap" style="display:none">
                <div class="sec-title">Ghi chu</div>
                <div id="mNote" style="background:#f8fafc;border-radius:8px;padding:10px 12px;font-size:13px;color:#475569"></div>
            </div>
            <div class="total-row">
                <span class="lbl">Tong tien</span>
                <span class="val" id="mTotal">—</span>
            </div>
        </div>
        <div class="modal-actions" id="modalActions"></div>
    </div>
</div>

<form id="statusForm" action="" method="POST" style="display:none">
    <input type="hidden" name="status" id="statusInput">
</form>

<!-- DATA NHUNG VAO SCRIPT TAG - TRANH ESCAPE HTML ATTRIBUTE -->
<script>
var BOOKINGS_DATA = <%- JSON.stringify((recentBookings||[]).map(function(b) {
    var days = Math.max(1, Math.ceil(
        (new Date(b.endDate)-new Date(b.startDate))/(1000*60*60*24)
    ));
    var total = b.totalAmount || (b.car ? b.car.pricePerDay*days : 0);
    return {
        id:            String(b._id),
        code:          String(b._id).slice(-8).toUpperCase(),
        status:        b.status,
        customerName:  b.customer ? b.customer.fullName      : '',
        customerEmail: b.customer ? b.customer.email         : '',
        customerPhone: b.customer ? (b.customer.phone || '') : '',
        carName:       b.car ? b.car.name                    : '',
        carPlate:      b.car ? b.car.licensePlate            : '',
        carImg:        (b.car && b.car.images && b.car.images.length > 0) ? b.car.images[0] : '',
        startDate:     b.startDate,
        endDate:       b.endDate,
        days:          days,
        total:         total,
        note:          b.customerNote || ''
    };
})) %>;
</script>

<script>
(function () {
    document.getElementById('btnNewCar').addEventListener('click', function () {
        window.location.href = '/admin/cars/new';
    });

    /* Click badge -> mo modal bang index */
    document.querySelectorAll('.badge-clickable').forEach(function (el) {
        el.addEventListener('click', function () {
            var idx = parseInt(this.getAttribute('data-idx'), 10);
            var b   = BOOKINGS_DATA[idx];
            if (b) openModal(b);
        });
    });

    function openModal(b) {
        document.getElementById('modalTitle').textContent = 'Don #' + b.code;

        var imgEl = document.getElementById('mCarImg');
        var imgPh = document.getElementById('mCarPh');
        if (b.carImg) {
            imgEl.src = b.carImg;
            imgEl.style.display = 'block';
            imgPh.style.display = 'none';
            imgEl.onerror = function () { imgEl.style.display='none'; imgPh.style.display='flex'; };
        } else {
            imgEl.style.display = 'none';
            imgPh.style.display = 'flex';
        }

        document.getElementById('mCarName').textContent  = b.carName    || '—';
        document.getElementById('mCarPlate').textContent = b.carPlate   || '—';
        document.getElementById('mCusName').textContent  = b.customerName  || '—';
        document.getElementById('mCusEmail').textContent = b.customerEmail || '—';
        document.getElementById('mCusPhone').textContent = b.customerPhone || '—';

        var fmt = function(d){ return new Date(d).toLocaleDateString('vi-VN'); };
        document.getElementById('mStart').textContent = fmt(b.startDate);
        document.getElementById('mEnd').textContent   = fmt(b.endDate);
        document.getElementById('mDays').textContent  = b.days + ' ngay';
        document.getElementById('mTotal').textContent = Number(b.total).toLocaleString('vi-VN') + 'd';

        var nw = document.getElementById('mNoteWrap');
        if (b.note) { document.getElementById('mNote').textContent = b.note; nw.style.display='block'; }
        else { nw.style.display = 'none'; }

        var actEl = document.getElementById('modalActions');
        actEl.innerHTML = '';

        var closeBtn = mkBtn('neutral', '&#x2715; Dong');
        closeBtn.addEventListener('click', closeModal);
        actEl.appendChild(closeBtn);

        if (b.status === 'pending') {
            var ap = mkBtn('approve', '&#x2713; Duyet don');
            ap.addEventListener('click', function(){ closeModal(); doSubmit(b.id,'confirmed'); });
            var cn = mkBtn('cancel', '&#x2715; Huy don');
            cn.addEventListener('click', function(){ closeModal(); doSubmit(b.id,'cancelled'); });
            actEl.appendChild(ap);
            actEl.appendChild(cn);
        } else if (b.status === 'confirmed') {
            var st = mkBtn('start', '&#x25B6; Bat dau thue');
            st.addEventListener('click', function(){ closeModal(); doSubmit(b.id,'active'); });
            var cn2 = mkBtn('cancel', '&#x2715; Huy don');
            cn2.addEventListener('click', function(){ closeModal(); doSubmit(b.id,'cancelled'); });
            actEl.appendChild(st);
            actEl.appendChild(cn2);
        } else if (b.status === 'active') {
            var done = mkBtn('done', '&#x2713; Hoan thanh');
            done.addEventListener('click', function(){ closeModal(); doSubmit(b.id,'completed'); });
            actEl.appendChild(done);
        }

        document.getElementById('detailModal').classList.add('open');
    }

    function mkBtn(cls, html) {
        var btn = document.createElement('button');
        btn.className = 'mab ' + cls;
        btn.innerHTML = html;
        return btn;
    }

    function doSubmit(id, status) {
        var form = document.getElementById('statusForm');
        form.action = '/admin/bookings/' + id;
        document.getElementById('statusInput').value = status;
        form.submit();
    }

    function closeModal() {
        document.getElementById('detailModal').classList.remove('open');
    }

    document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
    document.getElementById('detailModal').addEventListener('click', function(e){
        if (e.target === this) closeModal();
    });
})();
</script>

</body>
</html>
