<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác nhận đặt xe – CarRental</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar', { page: '', user }) %>

<div class="page-booking">
    <div class="container">
        <h1 class="page-title">Xác nhận đặt xe</h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error" style="margin-bottom:20px"><%= error %></div>
        <% } %>

        <div class="booking-layout">
            <!-- Left -->
            <div class="booking-left">
                <form action="/booking" method="POST">
                    <input type="hidden" name="carId" value="<%= car._id %>">
                    <input type="hidden" name="startDate" value="<%= startDate %>">
                    <input type="hidden" name="endDate" value="<%= endDate %>">

                    <div class="booking-step">
                        <div class="step-head">
                            <div class="step-num">1</div>
                            <h3>Thông tin khách hàng</h3>
                        </div>
                        <div class="step-body">
                            <div class="form-group">
                                <label>Họ và tên</label>
                                <input type="text" name="fullName" value="<%= user.fullName %>" required placeholder="Nhập họ và tên đầy đủ">
                            </div>
                            <div class="form-row-2">
                                <div class="form-group">
                                    <label>Số điện thoại</label>
                                    <input type="tel" name="phone" value="<%= user.phone || '' %>" required placeholder="0xxx xxx xxx">
                                </div>
                                <div class="form-group">
                                    <label>Email</label>
                                    <input type="email" name="email" value="<%= user.email %>" required>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Ghi chú (Tùy chọn)</label>
                                <textarea name="customerNote" rows="3" placeholder="Yêu cầu đặc biệt cho nhà xe..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="booking-step">
                        <div class="step-head">
                            <div class="step-num">2</div>
                            <h3>Phương thức thanh toán</h3>
                        </div>
                        <div class="step-body">
                            <div class="payment-list">
                                <label class="payment-item">
                                    <input type="radio" name="paymentMethod" value="bank_transfer" checked>
                                    <div class="payment-info">
                                        <strong>Chuyển khoản ngân hàng</strong>
                                        <span>Miễn phí giao dịch</span>
                                    </div>
                                    <span class="payment-icon">🏦</span>
                                </label>
                                <label class="payment-item">
                                    <input type="radio" name="paymentMethod" value="momo">
                                    <div class="payment-info">
                                        <strong>Thanh toán qua Ví MoMo</strong>
                                        <span>Tiện lợi, nhanh chóng</span>
                                    </div>
                                    <span class="payment-icon">💜</span>
                                </label>
                                <label class="payment-item">
                                    <input type="radio" name="paymentMethod" value="credit_card">
                                    <div class="payment-info">
                                        <strong>Thẻ tín dụng (Visa/Mastercard)</strong>
                                        <span>Phụ phí giao dịch 1.5%</span>
                                    </div>
                                    <span class="payment-icon">💳</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="form-check" style="margin-bottom:20px">
                        <input type="checkbox" id="agree" required>
                        <label for="agree">Bằng cách nhấn "Xác nhận đặt xe", tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a></label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block btn-lg">
                        XÁC NHẬN ĐẶT XE –
                        <%= Number(car.pricePerDay * totalDays).toLocaleString('vi-VN') %>đ
                    </button>
                </form>
            </div>

            <!-- Right: Summary -->
            <div class="booking-right">
                <div class="trip-summary">
                    <h3>Tóm tắt chuyến đi</h3>

                    <div class="summary-car">
                        <% if (car.images && car.images[0]) { %>
                            <img src="<%= car.images[0] %>" alt="<%= car.name %>">
                        <% } else { %>
                            <div class="summary-car-placeholder">🚗</div>
                        <% } %>
                        <div>
                            <div class="summary-car-name"><%= car.name %></div>
                            <div class="summary-car-sub"><%= car.type %> • <%= car.seats %> chỗ</div>
                            <div class="summary-car-rating">⭐ <%= car.rating ? car.rating.toFixed(1) : '4.5' %> (42 chuyến)</div>
                        </div>
                    </div>

                    <div class="summary-dates">
                        <div class="summary-date-item">
                            <div class="date-label">NHẬN XE</div>
                            <div class="date-val"><%= new Date(startDate).toLocaleDateString('vi-VN') %></div>
                        </div>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        <div class="summary-date-item">
                            <div class="date-label">TRẢ XE</div>
                            <div class="date-val"><%= new Date(endDate).toLocaleDateString('vi-VN') %></div>
                        </div>
                    </div>
                    <div class="summary-duration">Tổng thời gian: <strong><%= totalDays %> ngày</strong></div>

                    <div class="price-rows">
                        <div class="price-row">
                            <span>Giá thuê (<%= totalDays %> ngày)</span>
                            <span><%= Number(car.pricePerDay * totalDays).toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <div class="price-row">
                            <span>Phí dịch vụ</span>
                            <span>Miễn phí</span>
                        </div>
                        <div class="price-row total-row">
                            <span>Tổng cộng</span>
                            <span class="total-val"><%= Number(car.pricePerDay * totalDays).toLocaleString('vi-VN') %>đ</span>
                        </div>
                    </div>

                    <div class="cancel-policy">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        <div>
                            <strong>CHÍNH SÁCH HỦY CHUYẾN</strong>
                            <p>Hủy miễn phí trước 24h. Hủy sau thời gian này sẽ mất 30% tiền cọc.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

</body>
</html>
