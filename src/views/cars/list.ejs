<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách xe – CarRental</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 999;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: #fff;
            border-radius: 16px;
            padding: 28px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,.15);
        }
        .modal-title { font-size: 18px; font-weight: 700; margin-bottom: 6px; color: #1e293b; }
        .modal-sub { font-size: 13px; color: #94a3b8; margin-bottom: 20px; }
        .modal-car-name { font-weight: 600; color: #2563eb; }
        .modal-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
        .modal-field label {
            font-size: 12px; font-weight: 600; color: #64748b;
            text-transform: uppercase; letter-spacing: .5px;
            display: block; margin-bottom: 6px;
        }
        .modal-field input[type="date"] {
            width: 100%; padding: 10px 12px; border: 1.5px solid #e2e8f0;
            border-radius: 8px; font-size: 14px; font-family: inherit;
            color: #1e293b; outline: none; transition: border-color .15s; box-sizing: border-box;
        }
        .modal-field input[type="date"]:focus { border-color: #2563eb; }
        .modal-error { font-size: 13px; color: #ef4444; margin-bottom: 12px; display: none; }
        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; }
        .btn-cancel-modal {
            padding: 10px 18px; border-radius: 8px; border: 1.5px solid #e2e8f0;
            background: #fff; font-size: 14px; font-weight: 500; color: #64748b; cursor: pointer;
        }
        .btn-cancel-modal:hover { background: #f8fafc; }
        .btn-rented {
            background: #fff7ed;
            color: #ea580c;
            border: 1.5px solid #fed7aa;
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 600;
            cursor: default;
            font-family: inherit;
        }
    </style>
</head>
<body>

<%- include('../partials/navbar', { page: 'cars', user: typeof user !== 'undefined' ? user : null }) %>

<section class="hero-search">
    <div class="container">
        <h1>Tìm kiếm chiếc xe hoàn hảo cho hành trình của bạn</h1>
        <p>Hơn 500+ mẫu xe đời mới, giá thuê cạnh tranh và thủ tục nhanh gọn.</p>
        <form class="search-bar" action="/cars" method="GET">
            <div class="search-field">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <input type="text" name="city" placeholder="Thành phố, sân bay..." value="<%= query.city || '' %>">
            </div>
            <div class="search-sep"></div>
            <div class="search-field">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <input type="date" name="startDate" value="<%= query.startDate || '' %>">
                <span style="color:#cbd5e1;padding:0 4px">–</span>
                <input type="date" name="endDate" value="<%= query.endDate || '' %>">
            </div>
            <button type="submit" class="btn btn-primary">TÌM KIẾM</button>
        </form>
    </div>
</section>

<div class="container cars-layout">
    <aside class="filter-sidebar">
        <div class="filter-head">
            <span>Bộ lọc</span>
            <a href="/cars" class="reset-link">Đặt lại</a>
        </div>
        <form id="filterForm" action="/cars" method="GET">
            <input type="hidden" name="startDate" value="<%= query.startDate || '' %>">
            <input type="hidden" name="endDate"   value="<%= query.endDate   || '' %>">
            <input type="hidden" name="city"      value="<%= query.city      || '' %>">
            <input type="hidden" name="sortBy"    value="<%= query.sortBy    || '' %>">
            <div class="filter-block">
                <h4>Hãng xe</h4>
                <% const brands = ['Toyota','Honda','Hyundai','VinFast','Ford','Mercedes-Benz','BMW','Kia','Mazda']; %>
                <% const selectedBrands = Array.isArray(query.brand) ? query.brand : (query.brand ? [query.brand] : []); %>
                <% brands.forEach(function(b) { %>
                    <label class="chk-item">
                        <input type="checkbox" name="brand" value="<%= b %>"
                            <%= selectedBrands.includes(b) ? 'checked' : '' %>
                            onchange="this.form.submit()">
                        <span><%= b %></span>
                    </label>
                <% }); %>
            </div>
            <div class="filter-block">
                <h4>Loại xe</h4>
                <div class="type-btns">
                    <% ['','Sedan','SUV','Hatchback','MPV','Pickup','Van'].forEach(function(t) { %>
                        <button type="submit" name="type" value="<%= t %>"
                            class="type-btn <%= (query.type||'')===t ? 'active' : '' %>">
                            <%= t || 'Tất cả' %>
                        </button>
                    <% }); %>
                </div>
            </div>
            <div class="filter-block">
                <h4>Số chỗ ngồi</h4>
                <% [0,4,5,7,9].forEach(function(s) { %>
                    <label class="chk-item">
                        <input type="checkbox" name="seats" value="<%= s %>"
                            <%= (query.seats||[]).includes(String(s)) ? 'checked' : '' %>
                            onchange="this.form.submit()">
                        <span><%= s===0 ? 'Tất cả' : s+' chỗ' %></span>
                    </label>
                <% }); %>
            </div>
        </form>
    </aside>

    <div class="cars-main">
        <div class="cars-toolbar">
            <span class="result-count"><strong><%= total %></strong> xe tìm thấy</span>
            <div class="sort-wrap">
                <label>Sắp xếp:</label>
                <select id="sortSelect">
                    <option value="pricePerDay"  <%= (query.sortBy||'')==='pricePerDay'  ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                    <option value="-pricePerDay" <%= (query.sortBy||'')==='-pricePerDay' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                    <option value="-createdAt"   <%= (query.sortBy||'')==='-createdAt'   ? 'selected' : '' %>>Mới nhất</option>
                </select>
            </div>
        </div>

        <div class="car-grid">
            <% if (cars.length === 0) { %>
                <div class="empty-state">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
                    <p>Không tìm thấy xe phù hợp.<br>Thử thay đổi bộ lọc.</p>
                </div>
            <% } %>

            <% cars.forEach(function(car) { %>
            <div class="car-card" onclick="location.href='/cars/<%= car._id %>'">
                <div class="car-img">
                    <% if (car.images && car.images.length > 0) { %>
                        <img src="<%= car.images[0] %>" alt="<%= car.name %>" loading="lazy"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="car-no-img" style="display:none">
                            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
                        </div>
                    <% } else { %>
                        <div class="car-no-img">
                            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
                        </div>
                    <% } %>
                    <%- statusBadge(car.status) %>
                </div>
                <div class="car-body">
                    <div class="car-row">
                        <div>
                            <div class="car-name"><%= car.name %></div>
                            <div class="car-sub"><%= car.type %> • <%= car.brand %></div>
                        </div>
                        <div class="car-rating">⭐ <%= car.rating ? car.rating.toFixed(1) : '4.5' %></div>
                    </div>
                    <div class="car-specs">
                        <span>👥 <%= car.seats %> chỗ</span>
                        <span>⚙️ Tự động</span>
                        <span>📍 TP.HCM</span>
                    </div>
                    <div class="car-footer">
                        <div class="car-price">
                            <%= Number(car.pricePerDay).toLocaleString('vi-VN') %>đ
                            <span>/ngày</span>
                        </div>

                        <% if (car.status === 'rented') { %>
                            <% if (car.isAvailableForDates === false && query.startDate && query.endDate) { %>
                                <button class="btn-rented" onclick="event.stopPropagation()">
                                    Bận ngày này
                                </button>
                            <% } else { %>
                                <button
                                    class="btn btn-primary btn-sm rent-btn"
                                    style="background:#f59e0b;border-color:#f59e0b;"
                                    data-id="<%= car._id %>"
                                    data-name="<%= encodeURIComponent(car.name) %>"
                                    data-start="<%= query.startDate || '' %>"
                                    data-end="<%= query.endDate || '' %>"
                                    onclick="event.stopPropagation()">
                                    Đặt trước
                                </button>
                            <% } %>
                        <% } else { %>
                            <button
                                class="btn btn-primary btn-sm rent-btn"
                                data-id="<%= car._id %>"
                                data-name="<%= encodeURIComponent(car.name) %>"
                                data-start="<%= query.startDate || '' %>"
                                data-end="<%= query.endDate || '' %>"
                                onclick="event.stopPropagation()">
                                Thuê ngay
                            </button>
                        <% } %>

                    </div>
                </div>
            </div>
            <% }); %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
            <% if (currentPage > 1) { %>
                <a href="?page=<%= currentPage-1 %>" class="page-btn">‹</a>
            <% } %>
            <% for(var i=1; i<=totalPages; i++) { %>
                <% if (i===currentPage) { %>
                    <span class="page-btn active"><%= i %></span>
                <% } else if (i===1 || i===totalPages || Math.abs(i-currentPage)<=1) { %>
                    <a href="?page=<%= i %>" class="page-btn"><%= i %></a>
                <% } else if (Math.abs(i-currentPage)===2) { %>
                    <span class="page-dots">...</span>
                <% } %>
            <% } %>
            <% if (currentPage < totalPages) { %>
                <a href="?page=<%= currentPage+1 %>" class="page-btn">›</a>
            <% } %>
        </div>
        <% } %>
    </div>
</div>

<!-- Modal chọn ngày thuê -->
<div class="modal-overlay" id="bookingModal">
    <div class="modal-box">
        <div class="modal-title">Chọn ngày thuê xe</div>
        <div class="modal-sub">Xe: <span class="modal-car-name" id="modalCarName"></span></div>
        <div class="modal-row">
            <div class="modal-field">
                <label>Ngày nhận xe</label>
                <input type="date" id="modalStartDate">
            </div>
            <div class="modal-field">
                <label>Ngày trả xe</label>
                <input type="date" id="modalEndDate">
            </div>
        </div>
        <div class="modal-error" id="modalError"></div>
        <div class="modal-actions">
            <button class="btn-cancel-modal" id="btnCancelModal">Hủy</button>
            <button class="btn btn-primary" id="btnConfirmModal">Tiếp tục</button>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
(function () {
    var selectedCarId = null;

    document.querySelectorAll('.rent-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            selectedCarId = this.getAttribute('data-id');
            var name     = decodeURIComponent(this.getAttribute('data-name'));
            var preStart = this.getAttribute('data-start');
            var preEnd   = this.getAttribute('data-end');

            var today    = new Date().toISOString().split('T')[0];
            var tomorrow = new Date(Date.now() + 86400000).toISOString().split('T')[0];

            document.getElementById('modalCarName').textContent  = name;
            document.getElementById('modalStartDate').value      = preStart || today;
            document.getElementById('modalEndDate').value        = preEnd   || tomorrow;
            document.getElementById('modalStartDate').min        = today;
            document.getElementById('modalEndDate').min          = tomorrow;
            document.getElementById('modalError').style.display  = 'none';
            document.getElementById('bookingModal').classList.add('open');
        });
    });

    document.getElementById('btnCancelModal').addEventListener('click', function () {
        document.getElementById('bookingModal').classList.remove('open');
        selectedCarId = null;
    });

    document.getElementById('btnConfirmModal').addEventListener('click', function () {
        var startDate = document.getElementById('modalStartDate').value;
        var endDate   = document.getElementById('modalEndDate').value;
        var errEl     = document.getElementById('modalError');

        if (!startDate || !endDate) {
            errEl.textContent   = 'Vui lòng chọn đầy đủ ngày nhận và trả xe.';
            errEl.style.display = 'block';
            return;
        }
        if (new Date(endDate) <= new Date(startDate)) {
            errEl.textContent   = 'Ngày trả xe phải sau ngày nhận xe.';
            errEl.style.display = 'block';
            return;
        }

        window.location.href = '/booking?carId=' + selectedCarId +
                               '&startDate=' + startDate +
                               '&endDate='   + endDate;
    });

    document.getElementById('bookingModal').addEventListener('click', function (e) {
        if (e.target === this) {
            this.classList.remove('open');
            selectedCarId = null;
        }
    });

    document.getElementById('modalStartDate').addEventListener('change', function () {
        var next     = new Date(new Date(this.value).getTime() + 86400000).toISOString().split('T')[0];
        var endInput = document.getElementById('modalEndDate');
        endInput.min = next;
        if (endInput.value <= this.value) endInput.value = next;
    });

    document.getElementById('sortSelect').addEventListener('change', function () {
        var url = new URL(window.location.href);
        url.searchParams.set('sortBy', this.value);
        window.location.href = url.toString();
    });
})();
</script>
</body>
</html>
