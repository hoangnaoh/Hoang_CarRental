<aside class="admin-sidebar">
    <div class="sidebar-brand">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
        RENTAL.VN
    </div>
    <nav class="sidebar-nav">
        <div class="nav-label">TỔNG QUAN</div>
        <a href="/admin" class="sidebar-link <%= adminPage==='dashboard'?'active':'' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Bảng điều khiển
        </a>
        <div class="nav-label">QUẢN LÝ</div>
        <a href="/admin/cars" class="sidebar-link <%= adminPage==='cars'?'active':'' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
            Đội xe
        </a>
        <a href="/admin/bookings" class="sidebar-link <%= adminPage==='bookings'?'active':'' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Hợp đồng
        </a>
        <a href="/admin/customers" class="sidebar-link <%= adminPage==='customers'?'active':'' %>">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Khách hàng
        </a>
    </nav>
    <div class="sidebar-footer">
        <div class="sidebar-avatar"><%= user.fullName.charAt(0).toUpperCase() %></div>
        <div>
            <div class="sidebar-name"><%= user.fullName %></div>
            <div class="sidebar-role"><%= user.email %></div>
        </div>
    </div>
</aside>
